# Configuración de BunnyNet
# Obtén estos valores en tu dashboard de BunnyNet: https://dash.bunny.net/
VITE_BUNNY_API_KEY=
VITE_BUNNY_STORAGE_NAME=
VITE_BUNNY_REGION=de
VITE_BUNNY_PULL_ZONE=

# Configuración de Supabase (Base de Datos)
# Obtén estos valores en Settings -> API de tu proyecto Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Configuración de Google Gemini IA
# Obtén tu llave en: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=
