# Configuración de BunnyNet
# Obtén estos valores en tu dashboard de BunnyNet: https://dash.bunny.net/

# El "Password" de tu Storage Zone (tiene permisos de escritura)
VITE_BUNNY_API_KEY=

# El nombre exacto de tu Storage Zone (ej: daily-flow-storage)
VITE_BUNNY_STORAGE_NAME=

# La región de tu Storage Zone (de, ny, la, sg, sy). Default: de
VITE_BUNNY_REGION=de

# La URL pública de tu Pull Zone conectada (SIN slash al final)
# Ej: https://daily-flow.b-cdn.net
VITE_BUNNY_PULL_ZONE=
